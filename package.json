{
  "name": "homelab",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "init:agent-rules": "node scripts/init-agent-rules.mjs",
    "test": "node --test scripts/*.test.mjs && turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml,prisma}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
