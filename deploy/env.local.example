DATABASE_URL=postgresql://homelab:change-me@192.168.50.11:5432/homelab?schema=public
JWT_SECRET=change-me
JWT_EXPIRES_IN=1h

# Optional seed/update account. Leave empty when the target DB already owns users.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=

# Direct code deployment service ports. nginx proxies public ports to these local ports.
HOMELAB_BACKEND_PORT=3000
HOMELAB_ADMIN_PORT=3002
HOMELAB_PORTAL_PORT=3001

# Admin Next.js rewrite target for backend API. Defaults to local backend if unset.
ADMIN_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_API_BASE_URL=/api/backend
