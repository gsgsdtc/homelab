generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AgentStatus {
  initializing
  ready
  init_failed
}

enum ModelProviderType {
  OPENAI_COMPATIBLE
}

enum WorkflowReloadStatus {
  draft
  loading
  succeeded
  failed
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  agentName  String?
  scopes     String[]  @default([])
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Agent {
  id                  String      @id @default(cuid())
  name                String
  slug                String
  status              AgentStatus @default(initializing)
  workspaceName       String      @unique
  workspacePath       String      @unique
  modelProvider       String?
  modelSecretRef      String?
  soul                String      @default("")
  initializationError String?
  initializedAt       DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  workflows           AgentWorkflow[]
}

model ModelProvider {
  id              String            @id @default(cuid())
  name            String
  nameKey         String            @unique
  type            ModelProviderType @default(OPENAI_COMPATIBLE)
  baseUrl         String
  encryptedApiKey String
  defaultModel    String
  isActive        Boolean           @default(true)
  isDefault       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model AgentWorkflow {
  id          String               @id @default(cuid())
  agentId     String
  workflowKey String
  extension   String               @default("ts")
  relativePath String
  draftHash   String?
  activeHash  String?
  revision    String?
  reloadStatus WorkflowReloadStatus @default(draft)
  reloadError  String?              @db.Text
  loadedAt     DateTime?
  updatedById  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  agent    Agent                  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  versions AgentWorkflowVersion[]

  @@unique([agentId, workflowKey])
  @@index([agentId, reloadStatus])
}

model AgentWorkflowVersion {
  id                  String   @id @default(cuid())
  workflowId          String
  sourceHash          String
  source              String   @db.Text
  extension           String   @default("ts")
  relativePath        String
  createdById         String?
  promotedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  rollbackOfVersionId String?

  workflow          AgentWorkflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  rollbackOfVersion AgentWorkflowVersion?  @relation("WorkflowRollback", fields: [rollbackOfVersionId], references: [id])
  rollbackVersions  AgentWorkflowVersion[] @relation("WorkflowRollback")

  @@index([workflowId, promotedAt])
  @@index([workflowId, sourceHash])
}
