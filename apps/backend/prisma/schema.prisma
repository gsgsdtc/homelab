generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AgentStatus {
  initializing
  ready
  init_failed
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  agentName   String?
  scopes      String[]  @default([])
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Agent {
  id                  String      @id @default(cuid())
  name                String
  slug                String
  status              AgentStatus @default(initializing)
  workspaceName       String      @unique
  workspacePath       String      @unique
  modelProvider       String?
  modelSecretRef      String?
  soul                String      @default("")
  initializationError String?
  initializedAt       DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}
