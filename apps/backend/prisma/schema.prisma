generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AgentStatus {
  initializing
  ready
  init_failed
}

enum ModelProviderType {
  OPENAI_COMPATIBLE
}

enum AgentSkillSourceType {
  registry
  trusted_git
  system
}

enum AgentSkillOperation {
  install
  update
  remove
  self_update
}

enum AgentSkillChangeStatus {
  pending
  validating
  applying
  reloading
  succeeded
  failed
  rolled_back
  rollback_failed
}

enum AgentSkillReloadStatus {
  loaded
  failed
  pending_restart
  runtime_offline
  unknown
}

enum AgentSkillAuditStatus {
  audit_written
  audit_pending
  audit_failed
}

enum AgentSkillRollbackResult {
  not_required
  succeeded
  failed
  skipped
}

enum AgentSkillChangeResult {
  pending
  succeeded
  rejected
  failed
  rolled_back
  rollback_failed
  pending_restart
  runtime_offline
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  agentName  String?
  scopes     String[]  @default([])
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Agent {
  id                  String      @id @default(cuid())
  name                String
  slug                String
  status              AgentStatus @default(initializing)
  workspaceName       String      @unique
  workspacePath       String      @unique
  modelProvider       String?
  modelSecretRef      String?
  soul                String      @default("")
  initializationError String?
  initializedAt       DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  skills              AgentSkill[]
  skillChanges        AgentSkillChange[]
  selfUpdatePolicies  AgentSkillSelfUpdatePolicy[]
}

model ModelProvider {
  id              String            @id @default(cuid())
  name            String
  nameKey         String            @unique
  type            ModelProviderType @default(OPENAI_COMPATIBLE)
  baseUrl         String
  encryptedApiKey String
  defaultModel    String
  isActive        Boolean           @default(true)
  isDefault       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model TrustedSkillSource {
  id          String               @id @default(cuid())
  name        String
  sourceType  AgentSkillSourceType @default(trusted_git)
  url         String?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  skills      AgentSkill[]
  changes     AgentSkillChange[]
}

model AgentSkill {
  id                  String               @id @default(cuid())
  agentId             String
  skillName           String
  sourceType          AgentSkillSourceType
  sourceId            String?
  version             String
  commitSha           String?
  enabled             Boolean              @default(true)
  systemRequired      Boolean              @default(false)
  selfUpdateAllowed   Boolean              @default(false)
  activeConfigVersion String?
  lastChangeId        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  agent               Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  source              TrustedSkillSource?  @relation(fields: [sourceId], references: [id])

  @@unique([agentId, skillName])
  @@index([agentId])
  @@index([sourceId])
}

model AgentSkillChange {
  id                    String                    @id @default(cuid())
  agentId               String
  actorType             String                    @default("admin")
  actorId               String?
  operation             AgentSkillOperation
  skillName             String
  sourceType            AgentSkillSourceType
  sourceId              String?
  requestedVersion      String
  resolvedVersion       String?
  commitSha             String?
  previousVersion       String?
  previousConfigVersion String?
  activeConfigVersion   String?
  stagedConfigVersion   String?
  result                AgentSkillChangeResult    @default(pending)
  changeStatus          AgentSkillChangeStatus    @default(pending)
  reloadStatus          AgentSkillReloadStatus    @default(unknown)
  auditStatus           AgentSkillAuditStatus     @default(audit_written)
  rollbackResult        AgentSkillRollbackResult  @default(not_required)
  failedStage           String?
  errorCode             String?
  safeErrorSummary      String?
  leaseExpiresAt        DateTime?
  createdAt             DateTime                  @default(now())
  finishedAt            DateTime?

  agent                 Agent                     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  source                TrustedSkillSource?       @relation(fields: [sourceId], references: [id])

  @@index([agentId, changeStatus])
  @@index([agentId, createdAt])
  @@index([sourceId])
}

model AgentSkillSelfUpdatePolicy {
  id                String               @id @default(cuid())
  agentId           String
  skillName         String
  operation         AgentSkillOperation
  sourceType        AgentSkillSourceType
  sourceId          String?
  versionConstraint String
  allowLatest       Boolean              @default(false)
  allowPrerelease   Boolean              @default(false)
  expiresAt         DateTime?
  createdByAdminId  String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  agent             Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, skillName])
}
