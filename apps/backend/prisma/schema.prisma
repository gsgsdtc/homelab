generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ModelProviderType {
  OPENAI_COMPATIBLE
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  agentName   String?
  scopes      String[]  @default([])
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ModelProvider {
  id              String            @id @default(cuid())
  name            String
  nameKey         String            @unique
  type            ModelProviderType @default(OPENAI_COMPATIBLE)
  baseUrl         String
  encryptedApiKey String
  defaultModel    String
  isActive        Boolean           @default(true)
  isDefault       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}
